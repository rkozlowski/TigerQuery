  <data name="Opt_Query_Description" xml:space="preserve"><value>SQL query to run.</value></data>
  <data name="Opt_Run_File_Description" xml:space="preserve"><value>Path to the SQL script file to execute.</value></data>
  <data name="Opt_Run_Query_Description" xml:space="preserve"><value>Inline SQL query to execute.</value></data>
  <data name="Opt_Run_Mode_Description" xml:space="preserve"><value>Execution mode.</value></data>
